{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": { "contentSize": "1180px", "wideSize": "1440px" },
    "color": {
      "palette": [
        { "slug": "paper",     "color": "#FAFAF7",  "name": "Paper" },
        { "slug": "paper-soft","color": "#F2F0EB",  "name": "Paper Soft" },
        { "slug": "dark",      "color": "#0A0A08",  "name": "Dark" },
        { "slug": "ink",       "color": "#1A1714",  "name": "Ink" },
        { "slug": "corten",    "color": "#A7522C",  "name": "Corten" },
        { "slug": "gold",      "color": "#C9A96E",  "name": "Gold" },
        { "slug": "ok",        "color": "#2E8F4F",  "name": "Green" },
        { "slug": "whatsapp",  "color": "#25D366",  "name": "WhatsApp" }
      ],
      "defaultPalette": false, "defaultGradients": false
    },
    "typography": {
      "fontFamilies": [
        { "fontFamily": "'Cormorant Garamond', 'Times New Roman', serif", "slug": "display", "name": "Display (Cormorant)" },
        { "fontFamily": "'Manrope', system-ui, sans-serif", "slug": "body", "name": "Body (Manrope)" }
      ]
    }
  },
  "styles": {
    "color": { "background": "var(--wp--preset--color--paper)", "text": "var(--wp--preset--color--ink)" },
    "typography": { "fontFamily": "var(--wp--preset--font-family--body)", "fontSize": "1rem", "lineHeight": "1.6" }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
